import plotly.graph_objects as go
import numpy as np

# Parameters
size = 4
spacing = 1
coords = np.arange(-size, size + 1, spacing)
nodes = np.array(np.meshgrid(coords, coords, coords)).T.reshape(-1, 3)

# Define pyramid geometry
center = np.array([0, 0, 0])
pyramid_bases = {
    '+X': np.array([[ size, -size, -size],
                    [ size,  size, -size],
                    [ size,  size,  size],
                    [ size, -size,  size]]),
    '-X': np.array([[-size, -size, -size],
                    [-size,  size, -size],
                    [-size,  size,  size],
                    [-size, -size,  size]]),
    '+Y': np.array([[-size,  size, -size],
                    [ size,  size, -size],
                    [ size,  size,  size],
                    [-size,  size,  size]]),
    '-Y': np.array([[-size, -size, -size],
                    [ size, -size, -size],
                    [ size, -size,  size],
                    [-size, -size,  size]]),
    '+Z': np.array([[-size, -size,  size],
                    [ size, -size,  size],
                    [ size,  size,  size],
                    [-size,  size,  size]]),
    '-Z': np.array([[-size, -size, -size],
                    [ size, -size, -size],
                    [ size,  size, -size],
                    [-size,  size, -size]])
}

def pyramid_faces(base, apex):
    return [[base[0], base[1], apex],
            [base[1], base[2], apex],
            [base[2], base[3], apex],
            [base[3], base[0], apex]]

# Plot nodes
node_trace = go.Scatter3d(
    x=nodes[:, 0], y=nodes[:, 1], z=nodes[:, 2],
    mode='markers',
    marker=dict(size=2, color='black'),
    name='Nodes',
    visible=True
)

# Plot edges
edge_lines = []
for i in coords:
    for j in coords:
        for k in coords:
            if i < coords[-1]: edge_lines.append(((i, j, k), (i + spacing, j, k)))
            if j < coords[-1]: edge_lines.append(((i, j, k), (i, j + spacing, k)))
            if k < coords[-1]: edge_lines.append(((i, j, k), (i, j, k + spacing)))

x_lines, y_lines, z_lines = [], [], []
for p1, p2 in edge_lines:
    x_lines += [p1[0], p2[0], None]
    y_lines += [p1[1], p2[1], None]
    z_lines += [p1[2], p2[2], None]

edge_trace = go.Scatter3d(
    x=x_lines, y=y_lines, z=z_lines,
    mode='lines',
    line=dict(color='cornflowerblue', width=1),
    name='Edges',
    visible=True
)

# Correct color mapping (Dark = +, Light = −)
colors = ['darkred', 'lightcoral', 'darkgreen', 'lightgreen', 'darkblue', 'lightskyblue']
meshes = []
for idx, (face, base) in enumerate(pyramid_bases.items()):
    faces = pyramid_faces(base, center)
    verts = np.array([pt for tri in faces for pt in tri])
    i, j, k = list(range(0, len(verts), 3)), list(range(1, len(verts), 3)), list(range(2, len(verts), 3))
    meshes.append(go.Mesh3d(
        x=verts[:, 0], y=verts[:, 1], z=verts[:, 2],
        i=i, j=j, k=k,
        color=colors[idx],
        opacity=0.6,
        name=f'Pyramid {face}',
        visible=True
    ))

# Anchor point
anchor = go.Scatter3d(
    x=[0], y=[0], z=[0],
    mode='markers+text',
    marker=dict(size=4, color='red'),
    text=["i₀ (Recursive Anchor)"],
    textposition="top center",
    name='Anchor',
    visible=True
)

# Assemble all traces
data = [node_trace, edge_trace] + meshes + [anchor]

# Visibility structure
visibility_states = {
    "Nodes": [True] + [False]*(len(data)-1),
    "Edges": [False] + [True] + [False]*(len(data)-2),
    "Pyramids": [False, False] + [True]*6 + [False],
    "Anchor": [False]*(len(data)-1) + [True],
    "All On": [True]*len(data),
    "All Off": [False]*len(data)
}

# Buttons for toggling
buttons = [dict(label=label, method="update", args=[{"visible": vis}])
           for label, vis in visibility_states.items()]

layout = go.Layout(
    title="Unified Recursive Tensor Box — Canonical Color Mapped",
    scene=dict(aspectmode='cube'),
    updatemenus=[dict(
        type="buttons",
        direction="down",
        buttons=buttons,
        x=1.1,
        xanchor="left",
        y=1.1,
        yanchor="top"
    )],
    showlegend=True
)

fig = go.Figure(data=data, layout=layout)
fig.show()
